{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/renderer/*"],
      "@oudenos/design-system": ["../../packages/tuning-design-system/src"],
      "@oudenos/design-system/*": ["../../packages/tuning-design-system/src/*"],
      "@oudenos/tuning-shared-schema": ["../../packages/tuning-shared-schema/src"],
      "@oudenos/tuning-shared-schema/*": ["../../packages/tuning-shared-schema/src/*"],
      "@oudenos/system-analyzer": ["../../packages/system-analyzer/src"],
      "@oudenos/system-analyzer/*": ["../../packages/system-analyzer/src/*"]
    }
  },
  "include": ["src/renderer", "src/preload", "src/main"]
}
