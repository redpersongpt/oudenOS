# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
API_URL=https://api.ouden.cc
APP_URL=https://ouden.cc
OS_APP_URL=https://ouden.cc

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:password@localhost:5432/oudenos_tuning

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Min 32 chars — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-to-a-secure-random-string

# License token signing (optional RSA, PEM base64-encoded).
# Falls back to JWT_SECRET (HS256) if not set.
# Generate: openssl genrsa 2048 | base64
LICENSE_PRIVATE_KEY_BASE64=
LICENSE_PUBLIC_KEY_BASE64=

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_ANNUAL=price_...
STRIPE_PRICE_EXPERT_MONTHLY=price_...
STRIPE_PRICE_EXPERT_ANNUAL=price_...

# ─── OAuth ────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
APPLE_CLIENT_ID=com.oudenos.tuning

# ─── Email ────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG....
EMAIL_FROM=noreply@ouden.cc

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://ouden.cc,http://localhost:5173

# ─── Redirect URL allowlist ───────────────────────────────────────────────────
# Comma-separated hostnames allowed as Stripe checkout success/cancel URLs.
# Prevents open-redirect phishing after payment.
ALLOWED_REDIRECT_HOSTS=ouden.cc

# ─── Update metadata ──────────────────────────────────────────────────────────
LATEST_VERSION_STABLE=1.0.0
LATEST_VERSION_BETA=1.0.0
LATEST_VERSION_DOWNLOAD_URL=https://ouden.cc/downloads/os/oudenOS-setup.exe
CRITICAL_UPDATE=0
